{
  "markdown-pdf.type": "pdf",
  "markdown-pdf.format": "A4",
  "markdown-pdf.orientation": "landscape",

  "markdown-pdf.margin.top": "12mm",
  "markdown-pdf.margin.bottom": "13mm",
  "markdown-pdf.margin.left": "10mm",
  "markdown-pdf.margin.right": "10mm",

  "markdown-pdf.scale": 0.96,
  "markdown-pdf.printBackground": true,

  "markdown-pdf.includeDefaultStyles": false,

  "markdown-pdf.displayHeaderFooter": true,
  "markdown-pdf.headerTemplate": "<div></div>",
  "markdown-pdf.footerTemplate": "<div style=\"font-size:8px;color:#888;width:100%;text-align:center;font-family:Microsoft YaHei, SimSun, sans-serif;\">第 <span class=\"pageNumber\"></span> 页 / 共 <span class=\"totalPages\"></span> 页</div>",

  "markdown-pdf.stylesRelativePathFile": true,
  "markdown-pdf.styles": [
    "pdf-style.css"
  ],

  "markdown-pdf.breaks": false,
  "markdown-pdf.emoji": false,
  "markdown-pdf.highlight": true
}